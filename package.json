{
  "name": "unintentional",
  "version": "0.0.1",
  "workspaces": [
    "packages/*",
    "packages/react/*"
  ],
  "repository": "https://github.com/ricomadiko/unintentional",
  "private": true,
  "scripts": {
    "tokens": "yarn workspace @unintentional/tokens",
    "react-button": "yarn workspace @unintentional/react-button"
  },
  "prettier": {
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "singleQuote": false
  },
  "devDependencies": {
    "husky": "4.3.6",
    "typescript": "4.1.3",
    "tslib": "2.0.3",
    "tsdx": "0.14.1"
  }
}
